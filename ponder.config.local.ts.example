        },
      },
    },
    LockableUniswapV3Initializer: {
      abi: LockableUniswapV3InitializerABI,
      chain: {
        base: {
          startBlock: LOCAL_START_BLOCKS.base,
          address: base.addresses.v3.lockableV3Initializer,
