      },
    },
    DecayMulticurveInitializerHook: {
      abi: UniswapV4MulticurveInitializerHookABI,
      chain: {
        base: {
          startBlock: LOCAL_START_BLOCKS.base,
          address: base.addresses.v4.DecayMulticurveInitializerHook,
        },
